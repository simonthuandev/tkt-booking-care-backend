generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  user
  doctor
  admin
}

enum AuthProvider {
  local
  google
}

enum Gender {
  male
  female
  other
}

enum Relationship {
  self
  parent
  child
  spouse
  sibling
  other
}

enum HospitalType {
  public
  private
}

enum AppointmentStatus {
  pending     // Vừa đặt, chờ xác nhận
  confirmed   // Bác sĩ / admin đã xác nhận
  processing  // Bệnh nhân đang trong phòng khám
  completed   // Khám xong — có thể viết review
  cancelled   // Đã hủy
  no_show     // Bệnh nhân không đến
}

enum CancelledBy {
  patient
  doctor
  admin
}

// ─────────────────────────────────────────────────────────────
//  USER & AUTH
// ─────────────────────────────────────────────────────────────

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  password        String?
  firstName       String
  lastName        String
  avatar          String?
  role            UserRole      @default(user)
  provider        AuthProvider  @default(local)
  googleId        String?       @unique
  isActive        Boolean       @default(true)
  isEmailVerified Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  refreshTokens   RefreshToken[]
  patientProfiles PatientProfile[]
  doctorProfile   Doctor?
  newsArticles    News[]

  @@index([role])
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String
  tokenFamily String
  isRevoked   Boolean   @default(false)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenFamily])
  @@index([userId, isRevoked])
}

// ─────────────────────────────────────────────────────────────
//  PATIENT PROFILE
//  1 User có thể có nhiều hồ sơ (bản thân, con, bố mẹ...)
// ─────────────────────────────────────────────────────────────

model PatientProfile {
  id           String       @id @default(uuid())
  userId       String
  fullName     String
  dob          DateTime?
  gender       Gender?
  phoneNumber  String?
  address      String?
  relationship Relationship @default(self)
  isDefault    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]
  medicalRecords MedicalRecord[]

  @@index([userId])
  @@index([userId, isDefault])
}

// ─────────────────────────────────────────────────────────────
//  SPECIALTY
// ─────────────────────────────────────────────────────────────

model Specialty {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?  // tên icon hoặc URL
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  doctors     DoctorSpecialty[]

  @@index([slug])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────
//  HOSPITAL
// ─────────────────────────────────────────────────────────────

model Hospital {
  id           String       @id @default(uuid())
  name         String       @unique
  slug         String       @unique
  address      String
  city         String
  type         HospitalType @default(public)
  avatar       String?
  description  String?
  rating       Float        @default(0) // cached
  totalReviews Int          @default(0) // cached
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  doctors      DoctorHospital[]
  timeSlots    TimeSlot[]
  appointments Appointment[]
  reviews      Review[]

  @@index([slug])
  @@index([city])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────
//  DOCTOR
// ─────────────────────────────────────────────────────────────

model Doctor {
  id              String   @id @default(uuid())
  userId          String   @unique
  slug            String   @unique // VD: nguyen-thi-lan-d4f2
  bio             String?
  experience      Int      @default(0) // số năm kinh nghiệm
  licenseNumber   String?  @unique
  consultationFee Float    @default(0)
  rating          Float    @default(0) // cached
  totalReviews    Int      @default(0) // cached
  isVerified      Boolean  @default(false) // admin duyệt
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties     DoctorSpecialty[]
  hospitals       DoctorHospital[]
  timeSlots       TimeSlot[]
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  reviews         Review[]

  @@index([slug])
  @@index([isVerified, isActive])
  @@index([rating])
}

// ─────────────────────────────────────────────────────────────
//  DOCTOR ↔ SPECIALTY  (N-N)
// ─────────────────────────────────────────────────────────────

model DoctorSpecialty {
  doctorId    String
  specialtyId String
  isPrimary   Boolean  @default(false) // chuyên khoa chính

  doctor      Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([doctorId, specialtyId])
  @@index([specialtyId])
}

// ─────────────────────────────────────────────────────────────
//  DOCTOR ↔ HOSPITAL  (N-N + thông tin làm việc)
// ─────────────────────────────────────────────────────────────

model DoctorHospital {
  id          String   @id @default(uuid())
  doctorId    String
  hospitalId  String
  // VD: "MON,WED,FRI" — lưu dạng string để flexible
  workingDays String?
  startTime   String?  // "08:00"
  endTime     String?  // "17:00"
  isActive    Boolean  @default(true)

  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([doctorId, hospitalId])
  @@index([hospitalId])
}

// ─────────────────────────────────────────────────────────────
//  TIME SLOT
//  Slot cụ thể mỗi ngày — admin generate hàng loạt
// ─────────────────────────────────────────────────────────────

model TimeSlot {
  id         String   @id @default(uuid())
  doctorId   String
  hospitalId String
  date       DateTime @db.Date       // chỉ lưu ngày, không giờ
  startTime  String                  // "08:00"
  endTime    String                  // "08:30"
  isBooked   Boolean  @default(false)
  isBlocked  Boolean  @default(false) // admin/bác sĩ chủ động khóa

  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  appointment Appointment?

  @@unique([doctorId, date, startTime]) // tránh tạo slot trùng
  @@index([doctorId, date])
  @@index([hospitalId, date])
  @@index([isBooked, isBlocked])
}

// ─────────────────────────────────────────────────────────────
//  APPOINTMENT  ← CORE
// ─────────────────────────────────────────────────────────────

model Appointment {
  id               String            @id @default(uuid())
  patientProfileId String
  doctorId         String
  hospitalId       String
  timeSlotId       String            @unique // 1 slot chỉ có 1 appointment
  status           AppointmentStatus @default(pending)
  reason           String?           // lý do khám
  cancelReason     String?
  cancelledBy      CancelledBy?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id])
  doctor           Doctor         @relation(fields: [doctorId], references: [id])
  hospital         Hospital       @relation(fields: [hospitalId], references: [id])
  timeSlot         TimeSlot       @relation(fields: [timeSlotId], references: [id])

  medicalRecord    MedicalRecord?
  review           Review?

  @@index([patientProfileId, status])
  @@index([doctorId, status])
  @@index([hospitalId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
//  MEDICAL RECORD
//  Bác sĩ điền sau khi appointment = completed
// ─────────────────────────────────────────────────────────────

model MedicalRecord {
  id               String   @id @default(uuid())
  appointmentId    String   @unique // 1 appointment → 1 record
  patientProfileId String
  doctorId         String
  diagnosis        String?
  prescription     String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  appointment      Appointment    @relation(fields: [appointmentId], references: [id])
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id])
  doctor           Doctor         @relation(fields: [doctorId], references: [id])

  @@index([patientProfileId])
  @@index([doctorId])
}

// ─────────────────────────────────────────────────────────────
//  REVIEW
//  Chỉ tạo được khi appointment = completed
//  Trigger cập nhật cached rating của Doctor + Hospital
// ─────────────────────────────────────────────────────────────

model Review {
  id               String   @id @default(uuid())
  appointmentId    String   @unique // 1 appointment chỉ review 1 lần
  patientProfileId String
  doctorId         String
  hospitalId       String
  rating           Int      // 1-5
  comment          String?
  isVisible        Boolean  @default(true) // admin có thể ẩn
  createdAt        DateTime @default(now())

  // Relations
  appointment      Appointment    @relation(fields: [appointmentId], references: [id])
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id])
  doctor           Doctor         @relation(fields: [doctorId], references: [id])
  hospital         Hospital       @relation(fields: [hospitalId], references: [id])

  @@index([doctorId, isVisible])
  @@index([hospitalId, isVisible])
  @@index([patientProfileId])
}

// ─────────────────────────────────────────────────────────────
//  NEWS
// ─────────────────────────────────────────────────────────────

model News {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String    // full HTML hoặc markdown
  excerpt     String?   // tóm tắt ngắn
  thumbnail   String?
  category    String?
  authorId    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  author      User      @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([isPublished, publishedAt])
  @@index([category])
  @@index([authorId])
}
